{
  "name": "@voice-to-text/electron",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop voice-to-text app using local Whisper model",
  "main": "build/main/main.js",
  "scripts": {
    "dev": "tsc && node scripts/copy-assets.js && electron build/main/main.js",
    "build": "tsc && node scripts/copy-assets.js",
    "package": "tsc && node scripts/copy-assets.js && electron-builder --win"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "electron-store": "^8.1.0",
    "uiohook-napi": "^1.5.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.7",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.edupilot.voicetotext",
    "productName": "Voice to Text",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/uiohook-napi/**/*",
      "node_modules/@xenova/**/*",
      "node_modules/sharp/**/*",
      "node_modules/onnxruntime-node/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "sign": null,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
